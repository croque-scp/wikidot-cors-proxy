{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wikidot-cors-proxy",
  "main": "src/index.js",
  "compatibility_date": "2025-12-28",
  "observability": {
    "enabled": true,
  },
  "routes": [
    {
      "pattern": "wikidot.croquembouche.net",
      "custom_domain": true,
    },
  ],
  "ratelimits": [
    {
      "name": "RATE_LIMITER",
      "namespace_id": "1001",
      "simple": {
        "limit": 60,
        "period": 10,
      },
    },
  ],
}
